# Server
PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
# Get this from MongoDB Atlas dashboard -> Connect -> Drivers
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/moviemate?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_this_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS + email reset links)
CLIENT_URL=http://localhost:3000

# Email (SMTP) - for password reset
# Works with Gmail SMTP, SendGrid SMTP, Mailtrap, or Resend's SMTP relay
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="MovieMate <no-reply@moviemate.app>"
